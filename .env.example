INSTAGRAM_CLIENT_ID=xxxxxxx
INSTAGRAM_CLIENT_SECRET=xxxxxx
INSTAGRAM_AUTH_REDIRECT_URI=http://localhost:3000/instagram/auth

SESSION_SECRET=supersecret-token

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres-password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres

AWS_ACCESS_KEY_ID=xxxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
S3_REGION=eu-west-1
S3_BUCKET_NAME=s3.images.bucket

MAILGUN_API_KEY=xxxxxx
MAILGUN_DOMAIN=mydomain.com
MAILGUN_MAIL=mymail@mydomain.com

CONTACT_EMAIL=myemail@mail.com

# reCAPTCHA Enterprise (@google-cloud/recaptcha-enterprise → createAssessment)
# Clave pública de la clave Enterprise (widget / grecaptcha.enterprise.execute)
RECAPTCHA_SITE_KEY=
# ID de proyecto GCP (opcional si el JSON de la cuenta de servicio incluye project_id)
RECAPTCHA_PROJECT_ID=
# Render / PaaS: JSON completo de la cuenta de servicio (rol recaptchaenterprise.agent), o usa la variante *_B64
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=<base64 del fichero JSON>
# RECAPTCHA_SERVICE_ACCOUNT_JSON / RECAPTCHA_SERVICE_ACCOUNT_JSON_B64 (mismo contenido, nombres alternativos)
# Local: ruta al JSON o GOOGLE_APPLICATION_CREDENTIALS=ruta/al.json
RECAPTCHA_KEY_FILE=
# Opcional: misma acción que en el cliente
RECAPTCHA_EXPECTED_ACTION=
# Opcional: umbral mínimo de riskAnalysis.score (0–1, más alto = más probable legítimo). Por defecto 0.5
RECAPTCHA_MIN_SCORE=